# ========================================================================
#                     GAMESURGE PLATFORM ENVIRONMENT VARIABLES
# ========================================================================

# PostgreSQL Database Configuration
# POSTGRES_PASSWORD is used by docker-compose for the db service
POSTGRES_PASSWORD=your_postgres_password_here

# DATABASE_URL is used by the backend to connect to the database.
# Note: For local docker-compose run, use db as the host (e.g. postgres://postgres:password@db:5432/GameSurge)
DATABASE_URL=postgresql://postgres:your_postgres_password_here@localhost:5432/GameSurge

# App configuration
MIN_GAMES=500
CACHE_TTL_MINUTES=30
CORS_ALLOWED_ORIGINS=*

# JWT HMAC Signatures Secret (A highly secure random string)
JWT_SECRET=your_jwt_signing_secret_here

# Discord Developer OAuth2 configurations
# Retrieve Client ID from Discord Developer Portal (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback

# Steam Web API Key (Retrieve from https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=your_steam_web_api_key

# Docker Hub Credentials (used for CI/CD builds)
DOCKERHUB_USERNAME=your_dockerhub_username_here
