# API Base URL (Point this to your local or deployed backend URL)
VITE_API_BASE_URL=http://localhost:8080

# Discord OAuth2 Client ID (Retrieve from Discord Developer Portal)
VITE_DISCORD_CLIENT_ID=your_discord_client_id_here

# Discord Redirect URI (Must match the redirect URI registered in Discord Developer Portal)
VITE_DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback
