# PostgreSQL Database URL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/databasename

# Application Configuration
MIN_GAMES=500
CACHE_TTL_MINUTES=30

# CORS Security Configurations (Comma-separated origins, use * for development)
CORS_ALLOWED_ORIGINS=*

# Discord OAuth2 Configuration (Retrieve Client ID from Discord Developer Portal)
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback

STEAM_API_KEY=your_steam_web_api_key
JWT_SECRET=a_highly_secure_random_key_string